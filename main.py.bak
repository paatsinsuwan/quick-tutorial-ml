import numpy as np

one_dimensional_array = np.array([1.2, 2.4, 3.5, 4.7, 6.1, 7.2, 8.3, 9.5])
print(one_dimensional_array)

two_dimensional_array = np.array([[6, 5], [11, 7], [4, 8]])
print(two_dimensional_array)

sequence_of_integers = np.arange(5,12)
print(sequence_of_integers)

random_integers_btw_50_100 = np.random.randint(low=50, high=100, size=(6,))
print(random_integers_btw_50_100)

random_floats_btw_0_1 = np.random.random((6,))
print(random_floats_btw_0_1)

random_floats_btw_2_3 = random_floats_btw_0_1 + 2.0
print(random_floats_btw_2_3)

random_integers_btw_150_300 = random_integers_btw_50_100 * 3
print(random_integers_btw_150_300)